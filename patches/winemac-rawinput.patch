From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: WarChaos Apple Silicon contributors
Date: Thu, 19 Jun 2026 00:00:00 +0000
Subject: [PATCH] winemac.drv: Add relative mouse (raw input) mode

Ports the relative-pointer behavior from winewayland.drv (GitLab MR
!5869) to the macOS driver, fixing FPS mouselook lag. When the new
opt-in registry key HKCU\Software\Wine\Mac Driver\RawInput = Y is set,
always feed relative motion from the CGEvent deltas
(kCGMouseEventDeltaX/Y) instead of the pinned-cursor heuristic that
only emits relative at clip/desktop boundaries. win32u synthesizes
WM_INPUT for registered raw input devices (Bernon patchset, 2019).

The game registers for raw input via RegisterRawInputDevices but may
not call ClipCursor/ShowCursor (e.g. when it believes it's fullscreen
and the OS owns the cursor), so we can't key off the pointer-grab
state — just feed relative whenever RawInput is enabled.

Signed-off-by: WarChaos Apple Silicon contributors
---


diff --git a/dlls/winemac.drv/cocoa_app.m b/dlls/winemac.drv/cocoa_app.m
index 2a9dab2..79ac80d 100644
--- a/dlls/winemac.drv/cocoa_app.m
+++ b/dlls/winemac.drv/cocoa_app.m
@@ -1375,6 +1375,22 @@ static NSString* WineLocalizedString(unsigned int stringID)
                 absolute = TRUE;
                 forceNextMouseMoveAbsolute = FALSE;
             }
+            else if (use_raw_input)
+            {
+                /* RawInput=Y: always feed relative motion from the CGEvent
+                 * deltas (kCGMouseEventDeltaX/Y, i.e. NSEvent -deltaX/-deltaY)
+                 * so raw input devices registered via RegisterRawInputDevices
+                 * get proper WM_INPUT messages with real relative deltas.
+                 * Mirrors winewayland.drv relative pointer behavior (GitLab
+                 * MR !5869). The game registers for raw input but may not
+                 * call ClipCursor/ShowCursor (e.g. when it believes it's
+                 * already fullscreen and the OS owns the cursor), so we can't
+                 * key off the pointer-grab state — just feed relative whenever
+                 * RawInput is enabled. The forceNextMouseMoveAbsolute and
+                 * targetWindow-change checks above still establish an initial
+                 * absolute baseline when needed. */
+                absolute = FALSE;
+            }
             else
             {
                 // Send absolute move events if the cursor is in the interior of
diff --git a/dlls/winemac.drv/macdrv_cocoa.h b/dlls/winemac.drv/macdrv_cocoa.h
index 9a91edb..742dc5e 100644
--- a/dlls/winemac.drv/macdrv_cocoa.h
+++ b/dlls/winemac.drv/macdrv_cocoa.h
@@ -124,6 +124,7 @@ extern bool allow_immovable_windows;
 extern bool use_confinement_cursor_clipping;
 extern bool cursor_clipping_locks_windows;
 extern bool use_precise_scrolling;
+extern bool use_raw_input;
 extern int gl_surface_mode;
 extern CFDictionaryRef localized_strings;
 extern bool retina_enabled;  /* Whether Retina mode is enabled via registry setting. */
diff --git a/dlls/winemac.drv/macdrv_main.c b/dlls/winemac.drv/macdrv_main.c
index 9616824..14d57f7 100644
--- a/dlls/winemac.drv/macdrv_main.c
+++ b/dlls/winemac.drv/macdrv_main.c
@@ -53,6 +53,7 @@ BOOL allow_software_rendering = FALSE;
 bool allow_immovable_windows = true;
 bool use_confinement_cursor_clipping = true;
 bool cursor_clipping_locks_windows = true;
+bool use_raw_input = false;
 bool use_precise_scrolling = true;
 int gl_surface_mode = GL_SURFACE_IN_FRONT_OPAQUE;
 bool retina_enabled = false;
@@ -354,6 +355,9 @@ static void setup_options(void)
     if (!get_config_key(hkey, appkey, "CursorClippingLocksWindows", buffer, sizeof(buffer)))
         cursor_clipping_locks_windows = IS_OPTION_TRUE(buffer[0]);
 
+    if (!get_config_key(hkey, appkey, "RawInput", buffer, sizeof(buffer)))
+        use_raw_input = IS_OPTION_TRUE(buffer[0]);
+
     if (!get_config_key(hkey, appkey, "UsePreciseScrolling", buffer, sizeof(buffer)))
         use_precise_scrolling = IS_OPTION_TRUE(buffer[0]);
 
